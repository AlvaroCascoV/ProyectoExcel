@model MvcProyectoExcel.ViewModels.PositionsAdminViewModel
@{
    ViewData["Title"] = SharedLocalizer["PositionsTitle"];
    var error = ViewBag.ErrorMessage as string ?? TempData["ErrorMessage"] as string;
    var studentsById = Model.AllStudents.ToDictionary(s => s.Id);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@SharedLocalizer["PositionsTitle"]</h1>
    <a class="btn btn-sm btn-outline-secondary" asp-controller="Devices" asp-action="Index">
        <i class="bi bi-pc-display me-1"></i>
        @SharedLocalizer["DevicesTitle"]
    </a>
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end mb-3">
            <div class="col-md-6">
                <label class="form-label" for="courseId">@SharedLocalizer["CourseLabel"]</label>
                <form method="get" class="d-flex gap-2">
                    <select class="form-select form-select-sm" id="courseId" name="courseId" onchange="this.form.submit()">
                        @foreach (var c in Model.Courses)
                        {
                            if (Model.SelectedCourseId == c.Id)
                            {
                                <option value="@c.Id" selected="selected">@c.Name</option>
                            }
                            else
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        }
                    </select>
                    <noscript>
                        <button class="btn btn-sm btn-outline-primary" type="submit">@SharedLocalizer["Refresh"]</button>
                    </noscript>
                </form>
            </div>
        </div>

        <div class="text-muted small mb-2">@SharedLocalizer["SeedPositions"]</div>
        <form asp-action="Seed" method="post" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-md-3">
                <label class="form-label" for="classCode">@SharedLocalizer["ClassCode"]</label>
                <input class="form-control form-control-sm" id="classCode" name="classCode" value="T38" />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="from">@SharedLocalizer["From"]</label>
                <input class="form-control form-control-sm" id="from" name="from" type="number" value="1" min="1" />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="to">@SharedLocalizer["To"]</label>
                <input class="form-control form-control-sm" id="to" name="to" type="number" value="25" min="1" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-sm btn-outline-primary" type="submit">@SharedLocalizer["Create"]</button>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>@SharedLocalizer["Position"]</th>
            <th>@SharedLocalizer["DeviceAssigned"]</th>
            <th>@SharedLocalizer["AssignedStudent"]</th>
            <th style="width: 300px">@SharedLocalizer["AssignStudent"]</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Positions.Count == 0)
        {
            <tr><td colspan="5" class="text-center text-muted">@SharedLocalizer["NoPositionsYet"]</td></tr>
        }
        else
        {
            foreach (var p in Model.Positions)
            {
                <tr>
                    <td class="text-muted">@p.PositionId</td>
                    <td>
                        <span class="badge text-bg-primary">@p.ClassCode/@p.DeviceCode</span>
                    </td>
                    <td>
                        @if (p.CurrentDeviceId is not null)
                        {
                            <span class="small">ID @p.CurrentDeviceId</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @if (p.CurrentTajamarUserId is not null)
                        {
                            if (studentsById.TryGetValue(p.CurrentTajamarUserId.Value, out var assignedStudent))
                            {
                                <span class="small">@assignedStudent.FullName (@assignedStudent.Id)</span>
                            }
                            else
                            {
                                <span class="small">ID @p.CurrentTajamarUserId</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">@SharedLocalizer["StudentNotAssigned"]</span>
                        }
                    </td>
                    <td>
                        <form asp-action="AssignUser" method="post" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="positionId" value="@p.PositionId" />
                            <select class="form-select form-select-sm" name="tajamarUserId" aria-label="@SharedLocalizer["AssignStudent"]">
                                <option value="">@SharedLocalizer["SelectStudent"]</option>
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.Id">@s.FullName (@s.Id)</option>
                                }
                            </select>
                            <button class="btn btn-sm btn-outline-primary" type="submit">@SharedLocalizer["Save"]</button>
                        </form>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

