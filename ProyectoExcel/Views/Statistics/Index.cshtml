@model MvcProyectoExcel.ViewModels.StatisticsDashboardViewModel
@using System.Text.Json
@inject IWebHostEnvironment HostEnvironment
@{
    ViewData["Title"] = SharedLocalizer["Statistics"];
    var chartJsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var chartJson = JsonSerializer.Serialize(Model.ChartData, chartJsonOptions);
    var successMessage = TempData["SuccessMessage"] as string;
    var seedErrorMessage = TempData["ErrorMessage"] as string;
    var chartLabelsJson = JsonSerializer.Serialize(new Dictionary<string, string>
    {
        ["students"] = SharedLocalizer["ChartLabelStudents"].Value,
        ["realPercent"] = SharedLocalizer["ChartLabelRealPercent"].Value
    });
    var confirmSeedTestDataJson = JsonSerializer.Serialize(SharedLocalizer["ConfirmSeedTestData"].Value);
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="h3 mb-0">@SharedLocalizer["Statistics"]</h1>
    <div class="d-flex gap-2">
        @if (Model.Statistics is not null && Model.SelectedCourseId.HasValue)
        {
            @await Html.PartialAsync("_ExportMenu",
                new MvcProyectoExcel.ViewModels.ExportMenuViewModel
                {
                    PdfUrl = Url.Action("ExportPdf", new
                    {
                        courseId = Model.SelectedCourseId,
                        month = Model.SelectedMonth,
                        year = Model.SelectedYear,
                        minPercent = Model.MinPercent,
                        maxPercent = Model.MaxPercent
                    }),
                    ExcelUrl = Url.Action("Export", new
                    {
                        courseId = Model.SelectedCourseId,
                        month = Model.SelectedMonth,
                        year = Model.SelectedYear,
                        minPercent = Model.MinPercent,
                        maxPercent = Model.MaxPercent
                    })
                })
        }
        @if (HostEnvironment.IsDevelopment() && Model.SelectedCourseId.HasValue)
        {
            <form asp-action="SeedPresentWeek" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                <button type="submit" class="btn btn-sm btn-outline-secondary" id="seedPresentWeekBtn">
                    @SharedLocalizer["SeedTestData"]
                </button>
            </form>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrEmpty(seedErrorMessage))
{
    <div class="alert alert-danger">@seedErrorMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="get" class="row g-2 g-md-3 align-items-end mb-4 filter-row">
    <div class="col-12 col-md-4">
        <label class="form-label small" for="courseId">@SharedLocalizer["CourseLabel"]</label>
        <select class="form-select" id="courseId" name="courseId" onchange="this.form.submit()">
            @foreach (var course in Model.Courses)
            {
                if (Model.SelectedCourseId == course.Id)
                {
                    <option value="@course.Id" selected="selected">@course.Name</option>
                }
                else
                {
                    <option value="@course.Id">@course.Name</option>
                }
            }
        </select>
    </div>
    <div class="col-6 col-md-2">
        <label class="form-label small" for="month">@SharedLocalizer["MonthLabel"]</label>
        <select class="form-select" id="month" name="month" onchange="this.form.submit()">
            <option value="">@SharedLocalizer["AllOption"]</option>
            @for (var m = 1; m <= 12; m++)
            {
                if (Model.SelectedMonth == m)
                {
                    <option value="@m" selected="selected">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                }
                else
                {
                    <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                }
            }
        </select>
    </div>
    <div class="col-6 col-md-2">
        <label class="form-label small" for="year">@SharedLocalizer["YearLabel"]</label>
        <input class="form-control" type="number" id="year" name="year" min="2020" max="2030"
               value="@Model.SelectedYear" onchange="this.form.submit()" placeholder="@SharedLocalizer["AllOption"]" />
    </div>
    <div class="col-3 col-md-1">
        <label class="form-label small" for="minPercent">@SharedLocalizer["MinPercentLabel"]</label>
        <input class="form-control" type="number" step="0.1" min="0" max="100" id="minPercent" name="minPercent" value="@Model.MinPercent" />
    </div>
    <div class="col-3 col-md-1">
        <label class="form-label small" for="maxPercent">@SharedLocalizer["MaxPercentLabel"]</label>
        <input class="form-control" type="number" step="0.1" min="0" max="100" id="maxPercent" name="maxPercent" value="@Model.MaxPercent" />
    </div>
    <div class="col-6 col-md-2 d-flex gap-2">
        <button type="submit" class="btn btn-outline-primary flex-fill">@SharedLocalizer["Load"]</button>
    </div>
</form>

@if (Model.Statistics is not null)
{
    var stats = Model.Statistics;

    <p class="text-muted mb-3">
        @SharedLocalizer["CourseText"] <strong>@stats.CourseName</strong> —
        @SharedLocalizer["LectiveDaysText"] <strong>@stats.TotalClassDays</strong>@(stats.TotalClassDays == Attendance.Infrastructure.Services.LectiveDayCalendar.LectiveDaysPerYear ? SharedLocalizer["FullYearText"].Value : string.Empty)
    </p>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-6 text-primary">@stats.AverageRealAttendancePercentage%</div>
                    <div class="small text-muted">@SharedLocalizer["AverageRealAttendance"]</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="h4 mb-0 text-warning">@stats.AtRiskCount</div>
                    <div class="small text-muted">@SharedLocalizer["Below80Diploma"]</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="h4 mb-0 text-danger">@stats.BelowDropThresholdCount</div>
                    <div class="small text-muted">@SharedLocalizer["Below75AtRisk"]</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="h4 mb-0">@stats.Students.Count</div>
                    <div class="small text-muted">@SharedLocalizer["StudentsCount"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h6 mb-3">@SharedLocalizer["StatusDistribution"]</h2>
                    <canvas id="statusChart" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h6 mb-3">@SharedLocalizer["AttendanceBuckets"]</h2>
                    <canvas id="bucketChart" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h6 mb-3">@SharedLocalizer["Top5Students"]</h2>
                    <canvas id="topChart" height="220"></canvas>
                </div>
            </div>
        </div>
    </div>

    @if (Model.AtRiskRankings.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h6 mb-3">@SharedLocalizer["LowestAttendanceAtRisk"]</h2>
                <canvas id="atRiskChart" height="120"></canvas>
            </div>
        </div>
    }

    @if (stats.BelowDropThresholdCount > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
            <div><strong>@stats.BelowDropThresholdCount @SharedLocalizer["StudentsAtRiskAlert"]</strong> @SharedLocalizer["StudentsAtRiskAlertDetail"]</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }
    else if (stats.AtRiskCount > 0)
    {
        <div class="alert alert-warning alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
            <i class="bi bi-info-circle-fill fs-5 flex-shrink-0"></i>
            <div>@stats.AtRiskCount @SharedLocalizer["StudentsBelowDiplomaAlert"]</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="mb-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="ta-search-wrap">
            <i class="bi bi-search" aria-hidden="true"></i>
            <input type="text" id="statsSearch" class="form-control form-control-sm"
                   placeholder="@SharedLocalizer["SearchStudents"]" autocomplete="off" />
        </div>
        <span id="statsSearchCount" class="small text-muted d-none"></span>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle ta-table-sticky">
            <thead>
                <tr>
                    <th>@SharedLocalizer["TableNum"]</th>
                    <th>@SharedLocalizer["TableStudent"]</th>
                    <th>@SharedLocalizer["TableF"]</th>
                    <th>@SharedLocalizer["TableR"]</th>
                    <th>@SharedLocalizer["TableSAF"]</th>
                    <th>@SharedLocalizer["TableWeighted"]</th>
                    <th>@SharedLocalizer["TableRealPercent"]</th>
                    <th>@SharedLocalizer["TableFPercent"]</th>
                    <th>@SharedLocalizer["TableFRPercent"]</th>
                    <th>@SharedLocalizer["TableDiploma"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in stats.Students)
                {
                    var rowCss = student.AtRiskDrop ? "row-risk-danger"
                                  : !student.DiplomaEligible ? "row-risk-warning"
                                  : student.RealAttendancePercentage < 85 ? "row-risk-warning85"
                                  : "";
                    <tr class="@rowCss">
                        <td>@student.Rank</td>
                        <td>@student.FullName</td>
                        <td>@student.AbsentCount</td>
                        <td>@student.LateCount</td>
                        <td>@student.EarlyLeaveCount</td>
                        <td>@student.UnjustifiedWeighted.ToString("0.#")</td>
                        <td>@student.RealAttendancePercentage%</td>
                        <td>@student.AbsentFPercentage%</td>
                        <td>@student.AbsentFRPercentage%</td>
                        <td>
                            @if (student.AtRiskDrop)
                            {
                                <span class="badge text-bg-danger badge-pulse">@SharedLocalizer["StatusAtRisk"]</span>
                            }
                            else if (!student.DiplomaEligible)
                            {
                                <span class="badge text-bg-warning">@SharedLocalizer["StatusBelow80"]</span>
                            }
                            else if (student.BelowDiplomaWarning)
                            {
                                <span class="badge text-bg-warning">@SharedLocalizer["StatusBelow80"]</span>
                            }
                            else
                            {
                                <span class="badge text-bg-success">@SharedLocalizer["StatusOk"]</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.Statistics is not null)
{
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        const chartData = @Html.Raw(chartJson);

        function initChart(canvasId, config) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) {
                return;
            }

            new Chart(canvas, config);
        }

        const chartLabels = @Html.Raw(chartLabelsJson);
        const localizedStudents = chartLabels.students;
        const localizedRealPercent = chartLabels.realPercent;
        const confirmSeedTestData = @Html.Raw(confirmSeedTestDataJson);

        const seedPresentWeekBtn = document.getElementById("seedPresentWeekBtn");
        if (seedPresentWeekBtn) {
            seedPresentWeekBtn.closest("form")?.addEventListener("submit", (event) => {
                if (!confirm(confirmSeedTestData)) {
                    event.preventDefault();
                }
            });
        }

        const statusValues = chartData.statusValues ?? [];
        if (statusValues.some(v => v > 0)) {
            initChart('statusChart', {
                type: 'doughnut',
                data: {
                    labels: chartData.statusLabels ?? [],
                    datasets: [{ data: statusValues, backgroundColor: ['#198754', '#dc3545', '#ffc107', '#6c757d', '#0dcaf0', '#fd7e14', '#6610f2'] }]
                },
                options: { plugins: { legend: { position: 'bottom' } } }
            });
        }

        const bucketValues = chartData.bucketValues ?? [];
        if (bucketValues.some(v => v > 0)) {
            initChart('bucketChart', {
                type: 'bar',
                data: {
                    labels: chartData.bucketLabels ?? [],
                    datasets: [{ label: localizedStudents, data: bucketValues, backgroundColor: '#0d6efd' }]
                },
                options: { scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
            });
        }

        const topLabels = chartData.topStudentLabels ?? [];
        const topValues = chartData.topStudentValues ?? [];
        if (topLabels.length > 0) {
            const lowestTop = Math.min(...topValues);
            const topAxisMin = Math.max(70, Math.min(95, Math.floor(lowestTop - 1)));

            initChart('topChart', {
                type: 'bar',
                data: {
                    labels: topLabels,
                    datasets: [{ label: localizedRealPercent, data: topValues, backgroundColor: '#198754' }]
                },
                options: {
                    indexAxis: 'y',
                    scales: {
                        x: {
                            min: topAxisMin,
                            max: 100,
                            ticks: { stepSize: 1 }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: (ctx) => `${localizedRealPercent}: ${ctx.parsed.x}%`
                            }
                        }
                    }
                }
            });
        }

        const atRiskLabels = chartData.atRiskLabels ?? [];
        const atRiskValues = chartData.atRiskValues ?? [];
        if (atRiskLabels.length > 0) {
            initChart('atRiskChart', {
                type: 'bar',
                data: {
                    labels: atRiskLabels,
                    datasets: [{ label: localizedRealPercent, data: atRiskValues, backgroundColor: '#dc3545' }]
                },
                options: {
                    indexAxis: 'y',
                    scales: {
                        x: {
                            min: 70,
                            max: 100,
                            ticks: { stepSize: 1 }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: (ctx) => `${localizedRealPercent}: ${ctx.parsed.x}%`
                            }
                        }
                    }
                }
            });
        }
    </script>
    <script>
        (function () {
            'use strict';
            var input   = document.getElementById('statsSearch');
            var countEl = document.getElementById('statsSearchCount');
            var tbody   = document.querySelector('.ta-table-sticky tbody');
            if (!input || !tbody) return;
            input.addEventListener('input', function () {
                var q = input.value.trim().toLowerCase();
                var rows = tbody.querySelectorAll('tr');
                var n = 0;
                rows.forEach(function (row) {
                    var name = row.cells[1] ? row.cells[1].textContent.toLowerCase() : '';
                    var show = !q || name.includes(q);
                    row.style.display = show ? '' : 'none';
                    if (show) n++;
                });
                if (countEl) {
                    countEl.textContent = q ? n + ' resultado' + (n !== 1 ? 's' : '') : '';
                    countEl.classList.toggle('d-none', !q);
                }
            });
        })();
    </script>
}
}
