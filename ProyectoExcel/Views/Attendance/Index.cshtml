@model MvcProyectoExcel.ViewModels.AttendancePassListViewModel
@using Attendance.Infrastructure.Entities
@{
    ViewData["Title"] = SharedLocalizer["PassList"];
    var successMessage = TempData["SuccessMessage"] as string;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="h3 mb-0">@SharedLocalizer["PassList"]</h1>
    @if (Model.SelectedCourseId.HasValue && Model.Rows.Count > 0)
    {
        @await Html.PartialAsync("_ExportMenu",
            new MvcProyectoExcel.ViewModels.ExportMenuViewModel
            {
                PdfUrl = Url.Action("ExportPdf", new
                {
                    courseId = Model.SelectedCourseId,
                    date = Model.SelectedDate.ToString("yyyy-MM-dd")
                })
            })
    }
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="get" class="row g-2 g-md-3 align-items-end mb-4">
        <div class="col-12 col-md-5">
            <label class="form-label small" for="courseId">@SharedLocalizer["CourseLabel"]</label>
            <select class="form-select" id="courseId" name="courseId" onchange="this.form.submit()">
                @foreach (var course in Model.Courses)
                {
                    if (Model.SelectedCourseId == course.Id)
                    {
                        <option value="@course.Id" selected="selected">@course.Name</option>
                    }
                    else
                    {
                        <option value="@course.Id">@course.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label small" for="date">@SharedLocalizer["SessionDate"]</label>
            <input class="form-control" type="date" id="date" name="date"
                   value="@Model.SelectedDate.ToString("yyyy-MM-dd")"
                   max="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")"
                   onchange="this.form.submit()" />
        </div>
        <div class="col-6 col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary flex-fill">@SharedLocalizer["Load"]</button>
        </div>
    </form>

    @if (Model.PreviousDates.Count > 0)
    {
        <p class="small text-muted mb-3">
            @SharedLocalizer["PreviouslyRecordedDates"]
            @string.Join(", ", Model.PreviousDates.Take(10).Select(d => d.ToString("yyyy-MM-dd")))
            @if (Model.PreviousDates.Count > 10)
            {
                <span>…</span>
            }
        </p>
    }

    @if (Model.SelectedCourseId.HasValue)
    {
        <form asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="SelectedCourseId" value="@Model.SelectedCourseId" />
            <input type="hidden" name="SelectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="SelectedCourseName" value="@Model.SelectedCourseName" />

            @if (!string.IsNullOrEmpty(Model.SelectedCourseName))
            {
                <p class="text-muted mb-3">
                    @SharedLocalizer["CourseText"] <strong>@Model.SelectedCourseName</strong> —
                    @SharedLocalizer["DateText"] <strong>@Model.SelectedDate.ToString("yyyy-MM-dd")</strong>
                </p>
            }

            <div class="row g-2 align-items-center mb-3">
                <div class="col-12 col-md-6">
                    <div class="input-group">
                        <input id="studentSearchInput"
                               type="text"
                               class="form-control"
                               placeholder="@SharedLocalizer["SearchStudents"]"
                               autocomplete="off" />
                        <button id="studentSearchClear" class="btn btn-outline-secondary" type="button" aria-label="Clear">
                            &times;
                        </button>
                    </div>
                    <div id="studentSearchCount" class="small text-muted mt-1 d-none"></div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>@SharedLocalizer["TableNum"]</th>
                            <th>@SharedLocalizer["TableStudent"]</th>
                            <th style="min-width: 220px;">@SharedLocalizer["TableStatus"]</th>
                            <th>@SharedLocalizer["TableComment"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Rows.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">@SharedLocalizer["NoStudentsEnrolled"]</td>
                            </tr>
                        }
                        else
                        {
                            for (var i = 0; i < Model.Rows.Count; i++)
                            {
                                var row = Model.Rows[i];
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@row.StudentFullName</td>
                                    <td>
                                        <input type="hidden" name="Rows[@i].StudentId" value="@row.StudentId" />
                                        <input type="hidden" name="Rows[@i].StudentFullName" value="@row.StudentFullName" />
                                        <select class="form-select form-select-sm" name="Rows[@i].Status">
                                            @foreach (AttendanceStatus status in Enum.GetValues<AttendanceStatus>())
                                            {
                                                var labelKey = $"Status_{status}";
                                                var labelText = SharedLocalizer[labelKey].Value;
                                                if (string.IsNullOrEmpty(labelText) || labelText == labelKey)
                                                {
                                                    labelText = AttendanceStatusDisplay.GetLabel(status);
                                                }
                                                
                                                if (row.Status == status)
                                                {
                                                    <option value="@((int)status)" selected="selected">
                                                        @labelText
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option value="@((int)status)">
                                                        @labelText
                                                    </option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input class="form-control form-control-sm" type="text"
                                               name="Rows[@i].Comment" value="@row.Comment"
                                               maxlength="500" placeholder="@SharedLocalizer["OptionalPlaceholder"]" />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Rows.Count > 0)
            {
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">@SharedLocalizer["SaveAttendance"]</button>
                </div>
            }
        </form>
    }

@section Scripts {
    <script>
        (function () {
            const input = document.getElementById('studentSearchInput');
            const clearBtn = document.getElementById('studentSearchClear');
            const countEl = document.getElementById('studentSearchCount');
            const table = document.querySelector('table');
            const tbody = table ? table.querySelector('tbody') : null;

            if (!input || !clearBtn || !countEl || !tbody) return;

            const allRows = Array.from(tbody.querySelectorAll('tr'));

            function normalizeText(value) {
                return (value || '')
                    .toString()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .toLowerCase()
                    .trim();
            }

            function update() {
                const q = normalizeText(input.value);
                let visible = 0;

                for (const row of allRows) {
                    const cells = row.querySelectorAll('td');
                    const nameCell = cells.length > 1 ? cells[1] : null; // column index 1
                    const name = normalizeText(nameCell ? nameCell.textContent : '');

                    const show = q.length === 0 || name.includes(q);
                    row.classList.toggle('d-none', !show);
                    if (show) visible++;
                }

                if (q.length === 0) {
                    countEl.classList.add('d-none');
                    countEl.textContent = '';
                    return;
                }

                countEl.classList.remove('d-none');
                countEl.textContent = `${visible} / ${allRows.length}`;
            }

            input.addEventListener('input', update);
            clearBtn.addEventListener('click', function () {
                input.value = '';
                update();
                input.focus();
            });

            update();
        })();
    </script>
}
