@model MvcProyectoExcel.ViewModels.AttendancePassListViewModel
@using Attendance.Infrastructure.Entities
@using System.Text.Json
@{
    ViewData["Title"] = SharedLocalizer["PassList"];
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="h3 mb-0">@SharedLocalizer["PassList"]</h1>
    <div id="pdfExportContainer">
        @if (Model.SelectedCourseId.HasValue && Model.Rows.Count > 0)
        {
            @await Html.PartialAsync("_ExportMenu",
                new MvcProyectoExcel.ViewModels.ExportMenuViewModel
                {
                    PdfUrl = Url.Action("ExportPdf", new
                    {
                        courseId = Model.SelectedCourseId,
                        date = Model.SelectedDate.ToString("yyyy-MM-dd")
                    })
                })
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 border-0 shadow-sm mb-3" role="alert">
        <i class="bi bi-check-circle-fill fs-5 flex-shrink-0"></i>
        <div class="flex-grow-1">@successMessage</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-start gap-2 border-0 shadow-sm mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
        <div class="flex-grow-1">@Model.ErrorMessage</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-start gap-2 border-0 shadow-sm mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
        <div class="flex-grow-1">@errorMessage</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- MAIN GRID LAYOUT -->
<div class="row g-4">
    <!-- LEFT PANEL: CONTROLS & DYNAMIC CALENDAR -->
    <div class="col-12 col-lg-4">
        <!-- COURSE SELECTOR CARD -->
        <div class="card theme-card p-3 mb-4">
            <form method="get" id="filterForm">
                <div class="mb-3">
                    <label class="form-label text-muted small fw-semibold" for="courseId">@SharedLocalizer["CourseLabel"]</label>
                    <select class="form-select" id="courseId" name="courseId" onchange="showLoadingOverlay(); this.form.submit()">
                        @foreach (var course in Model.Courses)
                        {
                            if (Model.SelectedCourseId == course.Id)
                            {
                                <option value="@course.Id" selected="selected">@course.Name</option>
                            }
                            else
                            {
                                <option value="@course.Id">@course.Name</option>
                            }
                        }
                    </select>
                </div>
                <!-- HIDDEN SELECTOR DATE -->
                <input type="hidden" id="dateInput" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
            </form>
        </div>

        @if (Model.SelectedCourseId.HasValue)
        {
            <!-- CALENDAR UPLOAD CARD -->
            <div class="card theme-card p-3 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="h6 mb-0"><i class="bi bi-calendar3 me-1"></i> @SharedLocalizer["CourseCalendar"]</h5>
                    <button class="btn btn-link btn-sm text-decoration-none text-muted p-0" type="button" data-bs-toggle="collapse" data-bs-target="#uploadCollapse">
                        <i class="bi bi-chevron-down"></i>
                    </button>
                </div>

                <div class="collapse" id="uploadCollapse">
                    <div class="upload-zone text-center mb-3" id="dropZone">
                        <i class="bi bi-cloud-upload fs-1 text-primary mb-2"></i>
                        <p class="small text-muted mb-0">@SharedLocalizer["CalendarUploadInstructions"]</p>
                        <input type="file" id="fileInput" class="d-none" accept=".xlsx" />
                    </div>

                    <!-- CALENDAR PREVIEW PANEL -->
                    <div id="previewPanel" class="d-none border p-3 rounded mb-3 bg-body-tertiary animate__animated animate__fadeIn">
                        <h6 class="small fw-bold mb-2"><i class="bi bi-eye me-1"></i> @SharedLocalizer["CalendarPreview"]</h6>
                        <p class="small text-muted mb-2 text-truncate" id="previewFileName"></p>
                        
                        <div class="row g-2 mb-3 text-center">
                            <div class="col-4">
                                <div class="bg-success bg-opacity-10 text-success p-2 rounded border border-success border-opacity-25">
                                    <div class="small fw-semibold">@SharedLocalizer["LegendLective"]</div>
                                    <div class="fs-6 fw-bold" id="previewLectiveCount">0</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="bg-danger bg-opacity-10 text-danger p-2 rounded border border-danger border-opacity-25">
                                    <div class="small fw-semibold">@SharedLocalizer["LegendFestivo"]</div>
                                    <div class="fs-6 fw-bold" id="previewFestivoCount">0</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="bg-warning bg-opacity-10 text-warning p-2 rounded border border-warning border-opacity-25">
                                    <div class="small fw-semibold">@SharedLocalizer["LegendNoLectivo"]</div>
                                    <div class="fs-6 fw-bold" id="previewNoLectivoCount">0</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-primary flex-fill fw-bold shadow-sm" id="confirmUploadBtn"><i class="bi bi-check-circle me-1"></i> @SharedLocalizer["ConfirmAndSave"]</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary px-3" id="cancelUploadBtn"><i class="bi bi-x-circle me-1"></i> @SharedLocalizer["Cancel"]</button>
                        </div>
                    </div>
                </div>

                <!-- CALENDAR STATUS INDICATOR -->
                <div id="calendarStatus" class="p-2 rounded text-center small mb-1">
                    @if (Model.HasCalendar)
                    {
                        <div class="text-success border border-success bg-opacity-10 bg-success p-2 rounded">
                            <i class="bi bi-check-circle-fill me-1"></i> @string.Format(SharedLocalizer["CalendarLoadedStatus"].Value, Model.LectiveDaysCount)
                        </div>
                    }
                    else
                    {
                        <div class="text-warning border border-warning bg-opacity-10 bg-warning p-2 rounded">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> @SharedLocalizer["CalendarFallbackMode"]
                        </div>
                    }
                </div>
            </div>

            <!-- INTERACTIVE MONTHLY CALENDAR GRID -->
            <div class="card theme-card p-3 mb-4">
                <div class="calendar-header">
                    <button class="btn btn-sm btn-outline-secondary py-0 px-2" type="button" id="prevMonth"><i class="bi bi-chevron-left"></i></button>
                    <span class="fw-bold small" id="calendarMonthYear"></span>
                    <button class="btn btn-sm btn-outline-secondary py-0 px-2" type="button" id="nextMonth"><i class="bi bi-chevron-right"></i></button>
                </div>

                <div class="calendar-grid mb-2">
                    <div class="calendar-day-header">@SharedLocalizer["WeekdayMon"]</div>
                    <div class="calendar-day-header">@SharedLocalizer["WeekdayTue"]</div>
                    <div class="calendar-day-header">@SharedLocalizer["WeekdayWed"]</div>
                    <div class="calendar-day-header">@SharedLocalizer["WeekdayThu"]</div>
                    <div class="calendar-day-header">@SharedLocalizer["WeekdayFri"]</div>
                    <div class="calendar-day-header">@SharedLocalizer["WeekdaySat"]</div>
                    <div class="calendar-day-header">@SharedLocalizer["WeekdaySun"]</div>
                </div>

                <div class="calendar-grid" id="calendarDays">
                    <!-- Javascript will draw the days dynamically here -->
                </div>

                <div class="mt-3 d-flex flex-wrap gap-3 justify-content-center small text-muted">
                    <span class="d-flex align-items-center cursor-help" data-bs-toggle="tooltip" data-bs-placement="top" title="@SharedLocalizer["TooltipLective"]">
                        <span class="legend-dot lective"></span> @SharedLocalizer["LegendLective"]
                    </span>
                    <span class="d-flex align-items-center cursor-help" data-bs-toggle="tooltip" data-bs-placement="top" title="@SharedLocalizer["TooltipFestivo"]">
                        <span class="legend-dot festivo"></span> @SharedLocalizer["LegendFestivo"]
                    </span>
                    <span class="d-flex align-items-center cursor-help" data-bs-toggle="tooltip" data-bs-placement="top" title="@SharedLocalizer["TooltipNoLectivo"]">
                        <span class="legend-dot no-lective"></span> @SharedLocalizer["LegendNoLectivo"]
                    </span>
                    <span class="d-flex align-items-center cursor-help" data-bs-toggle="tooltip" data-bs-placement="top" title="@SharedLocalizer["TooltipPassed"]">
                        <span class="legend-dot passed"></span> @SharedLocalizer["LegendPassed"]
                    </span>
                </div>
            </div>
        }
    </div>

    <!-- RIGHT PANEL: ATTENDANCE ROW SHEET -->
    <div class="col-12 col-lg-8">
        @if (Model.SelectedCourseId.HasValue)
        {
            <div class="card theme-card p-4" id="attendanceCard">
                <form asp-action="Save" method="post" id="attendanceForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SelectedCourseId" value="@Model.SelectedCourseId" />
                    <input type="hidden" name="SelectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="SelectedCourseName" value="@Model.SelectedCourseName" />

                    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                        <div>
                            <h4 class="h5 mb-1"><i class="bi bi-clipboard-check me-1"></i> @SharedLocalizer["RollCallGrid"]</h4>
                            <p class="text-muted small mb-0">
                                @SharedLocalizer["CourseText"] <strong>@Model.SelectedCourseName</strong> —
                                @SharedLocalizer["DateText"] <strong class="fw-bold">@Model.SelectedDate.ToString("yyyy-MM-dd")</strong>
                            </p>
                        </div>
                        <div>
                            @if (Model.Rows.Count > 0)
                            {
                                <button type="submit" class="btn btn-sm btn-primary px-3 shadow"><i class="bi bi-floppy me-1"></i> @SharedLocalizer["SaveAttendance"]</button>
                            }
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover table-striped align-middle mb-0">
                            <thead>
                                <tr class="text-muted small text-uppercase">
                                    <th style="width: 60px;">#</th>
                                    <th>@SharedLocalizer["TableStudent"]</th>
                                    <th style="width: 250px;">@SharedLocalizer["TableStatus"]</th>
                                    <th>@SharedLocalizer["TableComment"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Rows.Count == 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-5">
                                            <div class="py-3">
                                                <i class="bi bi-people fs-1 opacity-50 mb-3"></i>
                                                <p class="mb-0">@SharedLocalizer["NoStudentsEnrolled"]</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    for (var i = 0; i < Model.Rows.Count; i++)
                                    {
                                        var row = Model.Rows[i];
                                        <tr>
                                            <td class="text-muted small">@(i + 1)</td>
                                            <td class="fw-semibold">@row.StudentFullName</td>
                                            <td>
                                                <input type="hidden" name="Rows[@i].StudentId" value="@row.StudentId" />
                                                <input type="hidden" name="Rows[@i].StudentFullName" value="@row.StudentFullName" />
                                                <select class="form-select form-select-sm" name="Rows[@i].Status">
                                                    @foreach (AttendanceStatus status in Enum.GetValues<AttendanceStatus>())
                                                    {
                                                        var labelKey = $"Status_{status}";
                                                        var labelText = SharedLocalizer[labelKey].Value;
                                                        if (string.IsNullOrEmpty(labelText) || labelText == labelKey)
                                                        {
                                                            labelText = AttendanceStatusDisplay.GetLabel(status);
                                                        }
                                                        
                                                        if (row.Status == status)
                                                        {
                                                            <option value="@status" selected="selected">
                                                                @labelText
                                                            </option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@status">
                                                                @labelText
                                                            </option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <input class="form-control form-control-sm" type="text"
                                                       name="Rows[@i].Comment" value="@row.Comment"
                                                       maxlength="500" placeholder="@SharedLocalizer["OptionalPlaceholder"]" />
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.Rows.Count > 0)
                    {
                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-primary px-4 shadow"><i class="bi bi-floppy me-1"></i> @SharedLocalizer["SaveAttendance"]</button>
                        </div>
                    }
                </form>
            </div>
        }
    </div>
</div>

@if (Model.SelectedCourseId.HasValue)
{
    var attendanceI18n = new Dictionary<string, string>
    {
        ["previewFileWithSize"] = SharedLocalizer["PreviewFileWithSize"].Value,
        ["errorOnlyXlsx"] = SharedLocalizer["ErrorOnlyXlsxAllowed"].Value,
        ["generatingPreview"] = SharedLocalizer["CalendarGeneratingPreview"].Value,
        ["errorMessagePrefix"] = SharedLocalizer["ErrorMessagePrefix"].Value,
        ["errorNetworkConnectionFailed"] = SharedLocalizer["ErrorNetworkConnectionFailed"].Value,
        ["saving"] = SharedLocalizer["Saving"].Value,
        ["calendarSavedReloading"] = SharedLocalizer["CalendarSavedReloading"].Value,
        ["confirmAndSave"] = SharedLocalizer["ConfirmAndSave"].Value,
        ["errorSavingFormat"] = SharedLocalizer["ErrorSavingFormat"].Value,
        ["errorUploadFailedNetwork"] = SharedLocalizer["ErrorUploadFailedNetwork"].Value,
        ["calendarRoomPrefix"] = SharedLocalizer["CalendarRoomPrefix"].Value,
        ["tooltipPassed"] = SharedLocalizer["TooltipPassed"].Value,
        ["calendarDayInfo"] = SharedLocalizer["CalendarDayInfo"].Value
    };
    var attendanceScriptConfig = new Dictionary<string, object>
    {
        ["i18n"] = attendanceI18n,
        ["selectedDate"] = Model.SelectedDate.ToString("yyyy-MM-dd"),
        ["attendanceIndexUrl"] = Url.Action("Index", "Attendance") ?? string.Empty,
        ["courseId"] = Model.SelectedCourseId!.Value
    };
    <script>
        function formatString(template, ...args) {
            return args.reduce((result, arg, index) => result.replace(`{${index}}`, arg), template);
        }

        function formatMonthYearLabel(year, month) {
            const pageLocale = document.documentElement.lang || "es";
            return new Intl.DateTimeFormat(pageLocale, { month: "long", year: "numeric" })
                .format(new Date(year, month, 1));
        }

        // Calendar dynamic lookup tables
        const scriptConfig = @Html.Raw(JsonSerializer.Serialize(attendanceScriptConfig));
        const i18n = scriptConfig.i18n;
        let courseCalendar = @Html.Raw(Model.CalendarJson ?? "[]");
        const previousDates = new Set(@Html.Raw(JsonSerializer.Serialize(Model.PreviousDates?.Select(d => d.ToString("yyyy-MM-dd")) ?? Array.Empty<string>())));
        const courseId = scriptConfig.courseId;
        const attendanceIndexUrl = scriptConfig.attendanceIndexUrl;
        
        let minCalendarDate = null;
        let maxCalendarDate = null;
        if (courseCalendar && courseCalendar.length > 0) {
            const dates = courseCalendar.map(entry => new Date(entry.Date.split('T')[0] + "T00:00:00"));
            minCalendarDate = new Date(Math.min(...dates));
            maxCalendarDate = new Date(Math.max(...dates));
        }
        
        let selectedDateStr = scriptConfig.selectedDate;
        let currentDate = new Date(selectedDateStr + "T00:00:00");
        let viewYear = currentDate.getFullYear();
        let viewMonth = currentDate.getMonth(); // 0-indexed

        // Create quick calendar lookup map
        let calendarMap = {};
        function rebuildCalendarMap() {
            calendarMap = {};
            courseCalendar.forEach(entry => {
                // Keep only yyyy-mm-dd
                const key = entry.Date.split('T')[0];
                calendarMap[key] = entry;
            });
        }
        rebuildCalendarMap();

        // Elements
        const calendarMonthYear = document.getElementById("calendarMonthYear");
        const calendarDays = document.getElementById("calendarDays");
        const prevMonthBtn = document.getElementById("prevMonth");
        const nextMonthBtn = document.getElementById("nextMonth");
        const dateInput = document.getElementById("dateInput");
        const filterForm = document.getElementById("filterForm");

        function drawCalendar() {
            calendarDays.innerHTML = "";
            calendarMonthYear.textContent = formatMonthYearLabel(viewYear, viewMonth);

            // First day of the view month
            const firstDayIndex = new Date(Date.UTC(viewYear, viewMonth, 1)).getUTCDay(); // Sun=0, Mon=1, etc.
            // Adjust so week starts on Monday
            const startOffset = firstDayIndex === 0 ? 6 : firstDayIndex - 1;

            // Total days in the view month
            const totalDaysInMonth = new Date(Date.UTC(viewYear, viewMonth + 1, 0)).getUTCDate();

            // Total days in the previous month (for padding)
            const prevMonthTotalDays = new Date(Date.UTC(viewYear, viewMonth, 0)).getUTCDate();

            // 1. Draw padding from previous month
            for (let i = startOffset; i > 0; i--) {
                const day = prevMonthTotalDays - i + 1;
                const cell = document.createElement("div");
                cell.className = "calendar-cell other-month disabled";
                cell.textContent = day;
                calendarDays.appendChild(cell);
            }

            // 2. Draw current month days
            for (let day = 1; day <= totalDaysInMonth; day++) {
                const cell = document.createElement("div");
                cell.className = "calendar-cell";
                cell.textContent = day;

                // Format date string as yyyy-MM-dd
                const mStr = String(viewMonth + 1).padStart(2, '0');
                const dStr = String(day).padStart(2, '0');
                const dateKey = `${viewYear}-${mStr}-${dStr}`;

                // Mark selected day
                if (dateKey === selectedDateStr) {
                    cell.classList.add("selected");
                }

                // Retrieve calendar info
                const calendarInfo = calendarMap[dateKey];
                let isLective = false;

                if (courseCalendar && courseCalendar.length > 0) {
                    if (calendarInfo && calendarInfo.IsLective) {
                        isLective = true;
                    }
                } else {
                    const curD = new Date(Date.UTC(viewYear, viewMonth, day));
                    const dayOfWeek = curD.getUTCDay();
                    if (dayOfWeek !== 0 && dayOfWeek !== 6) {
                        isLective = true;
                    }
                }

                // Check if date is in the past in browser's local timezone
                const todayObj = new Date();
                const yStr = todayObj.getFullYear();
                const mStr2 = String(todayObj.getMonth() + 1).padStart(2, '0');
                const dStr2 = String(todayObj.getDate()).padStart(2, '0');
                const todayStr = `${yStr}-${mStr2}-${dStr2}`;
                const isPast = dateKey < todayStr;

                // Add record indicator dot & mark as passed (blue)
                if (previousDates.has(dateKey) || (isPast && isLective)) {
                    cell.classList.add("passed");
                }
                if (previousDates.has(dateKey)) {
                    const dot = document.createElement("span");
                    dot.className = "recorded-dot";
                    dot.setAttribute("data-bs-toggle", "tooltip");
                    dot.setAttribute("data-bs-placement", "top");
                    dot.setAttribute("title", i18n.tooltipPassed);
                    cell.appendChild(dot);
                }

                let isClickable = true;

                if (courseCalendar && courseCalendar.length > 0) {
                    // --- Custom Calendar Mode ---
                    if (calendarInfo) {
                        if (calendarInfo.IsLective) {
                            cell.classList.add("lective");
                        } else if (calendarInfo.DayType === "FESTIVO") {
                            cell.classList.add("festivo");
                            isClickable = false;
                        } else if (calendarInfo.DayType === "NO LECTIVO") {
                            cell.classList.add("no-lective");
                            isClickable = false;
                        }

                        // Setup Tooltip
                        if (calendarInfo.Module || calendarInfo.Teacher || calendarInfo.Room) {
                            const tooltip = document.createElement("span");
                            tooltip.className = "custom-tooltip shadow";
                            let tipHtml = `<strong>${calendarInfo.DayType || i18n.calendarDayInfo}</strong>`;
                            if (calendarInfo.Module) tipHtml += `<br>${calendarInfo.Module}`;
                            if (calendarInfo.Teacher) tipHtml += `<br><i class="bi bi-person-workspace me-1"></i> ${calendarInfo.Teacher}`;
                            if (calendarInfo.Room) tipHtml += `<br><i class="bi bi-geo-alt me-1"></i> ${formatString(i18n.calendarRoomPrefix, calendarInfo.Room)}`;
                            tooltip.innerHTML = tipHtml;
                            cell.appendChild(tooltip);
                        }
                    } else {
                        // Days outside calendar range or missing calendar entry in Custom Calendar Mode
                        const curD = new Date(Date.UTC(viewYear, viewMonth, day));
                        const dayOfWeek = curD.getUTCDay();
                        
                        if (dayOfWeek === 0 || dayOfWeek === 6) {
                            cell.classList.add("weekend");
                        } else {
                            cell.classList.add("other-month"); // Gray out weekdays outside calendar range
                            cell.style.opacity = "0.25";
                        }
                        cell.classList.add("disabled");
                        isClickable = false;
                    }
                } else {
                    // --- Fallback Mode (No custom calendar loaded) ---
                    const curD = new Date(Date.UTC(viewYear, viewMonth, day));
                    const dayOfWeek = curD.getUTCDay(); // Sun=0, Sat=6

                    if (dayOfWeek === 0 || dayOfWeek === 6) {
                        cell.classList.add("weekend");
                        isClickable = false;
                    } else {
                        cell.classList.add("lective");
                    }
                }

                if (isClickable) {
                    cell.addEventListener("click", () => {
                        // Smooth premium AJAX loading
                        const attendanceCard = document.getElementById("attendanceCard");
                        if (attendanceCard) {
                            attendanceCard.classList.add("loading");
                        }

                        // Immediate visual feedback for selection
                        const allCells = calendarDays.querySelectorAll(".calendar-cell");
                        allCells.forEach(c => c.classList.remove("selected"));
                        cell.classList.add("selected");

                        selectedDateStr = dateKey;
                        dateInput.value = dateKey;
                        const url = `${attendanceIndexUrl}?courseId=${courseId}&date=${dateKey}`;
                        
                        fetch(url)
                            .then(res => {
                                if (!res.ok) throw new Error("Network response was not ok");
                                return res.text();
                            })
                            .then(html => {
                                const parser = new DOMParser();
                                const doc = parser.parseFromString(html, "text/html");
                                
                                const newForm = doc.getElementById("attendanceForm");
                                const oldForm = document.getElementById("attendanceForm");
                                
                                if (newForm && oldForm) {
                                    oldForm.innerHTML = newForm.innerHTML;
                                    
                                    // Sincronizar inputs ocultos si fuera necesario
                                    const oldSelectedDateInput = oldForm.querySelector('input[name="SelectedDate"]');
                                    if (oldSelectedDateInput) {
                                        oldSelectedDateInput.value = dateKey;
                                    }
                                }
                                
                                const newPdfContainer = doc.getElementById("pdfExportContainer");
                                const oldPdfContainer = document.getElementById("pdfExportContainer");
                                if (newPdfContainer && oldPdfContainer) {
                                    oldPdfContainer.innerHTML = newPdfContainer.innerHTML;
                                }
                                
                                // Re-inicializar tooltips y eventos
                                if (typeof initTooltips === "function") {
                                    initTooltips();
                                }
                            })
                            .catch(err => {
                                console.error("AJAX loading failed, falling back to reload:", err);
                                showLoadingOverlay();
                                filterForm.submit();
                            })
                            .finally(() => {
                                if (attendanceCard) {
                                    attendanceCard.classList.remove("loading");
                                }
                            });
                    });
                } else {
                    cell.classList.add("disabled");
                }

                calendarDays.appendChild(cell);
            }

            // 3. Draw padding for next month (fill up grid to 42 cells if needed)
            const drawnCellsCount = startOffset + totalDaysInMonth;
            const remainingPadding = drawnCellsCount > 35 ? 42 - drawnCellsCount : 35 - drawnCellsCount;
            for (let i = 1; i <= remainingPadding; i++) {
                const cell = document.createElement("div");
                cell.className = "calendar-cell other-month disabled";
                cell.textContent = i;
                calendarDays.appendChild(cell);
            }

            if (typeof initTooltips === 'function') {
                initTooltips();
            }
        }

        // Navigate Months
        prevMonthBtn.addEventListener("click", () => {
            viewMonth--;
            if (viewMonth < 0) {
                viewMonth = 11;
                viewYear--;
            }
            drawCalendar();
        });

        nextMonthBtn.addEventListener("click", () => {
            viewMonth++;
            if (viewMonth > 11) {
                viewMonth = 0;
                viewYear++;
            }
            drawCalendar();
        });

        // Initialize Calendar Draw
        drawCalendar();

        // DRAG & DROP EXCEL FILE UPLOAD LOGIC
        const dropZone = document.getElementById("dropZone");
        const fileInput = document.getElementById("fileInput");
        const calendarStatus = document.getElementById("calendarStatus");
        const previewPanel = document.getElementById("previewPanel");
        const previewFileName = document.getElementById("previewFileName");
        const previewLectiveCount = document.getElementById("previewLectiveCount");
        const previewFestivoCount = document.getElementById("previewFestivoCount");
        const previewNoLectivoCount = document.getElementById("previewNoLectivoCount");
        const confirmUploadBtn = document.getElementById("confirmUploadBtn");
        const cancelUploadBtn = document.getElementById("cancelUploadBtn");

        let activeFile = null;

        dropZone.addEventListener("click", () => fileInput.click());

        dropZone.addEventListener("dragover", (e) => {
            e.preventDefault();
            dropZone.classList.add("dragover");
        });

        ["dragleave", "dragend"].forEach(type => {
            dropZone.addEventListener(type, () => {
                dropZone.classList.remove("dragover");
            });
        });

        dropZone.addEventListener("drop", (e) => {
            e.preventDefault();
            dropZone.classList.remove("dragover");
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleFileSelection(files[0]);
            }
        });

        fileInput.addEventListener("change", (e) => {
            if (e.target.files.length > 0) {
                handleFileSelection(e.target.files[0]);
            }
        });

        function handleFileSelection(file) {
            if (!file.name.endsWith(".xlsx")) {
                alert(i18n.errorOnlyXlsx);
                return;
            }

            activeFile = file;

            const formData = new FormData();
            formData.append("file", file);
            formData.append("courseId", courseId);

            calendarStatus.innerHTML = `
                <div class="text-info border border-info bg-opacity-10 bg-info p-2 rounded d-flex align-items-center justify-content-center gap-2">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span>${i18n.generatingPreview}</span>
                </div>
            `;

            fetch(`/Attendance/PreviewCalendar?courseId=${courseId}`, {
                method: "POST",
                body: formData,
                headers: {
                    "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    calendarStatus.innerHTML = "";
                    dropZone.classList.add("d-none");
                    
                    previewFileName.textContent = formatString(i18n.previewFileWithSize, file.name, Math.round(file.size / 1024));
                    previewLectiveCount.textContent = data.lectiveDays;
                    previewFestivoCount.textContent = data.festivos;
                    previewNoLectivoCount.textContent = data.noLectivos;
                    
                    previewPanel.classList.remove("d-none");
                } else {
                    calendarStatus.innerHTML = `
                        <div class="text-danger border border-danger bg-opacity-10 bg-danger p-2 rounded">
                            <i class="bi bi-exclamation-octagon-fill me-1"></i> ${formatString(i18n.errorMessagePrefix, data.message)}
                        </div>
                    `;
                }
            })
            .catch(err => {
                calendarStatus.innerHTML = `
                    <div class="text-danger border border-danger bg-opacity-10 bg-danger p-2 rounded">
                        <i class="bi bi-exclamation-octagon-fill me-1"></i> ${i18n.errorNetworkConnectionFailed}
                    </div>
                `;
            });
        }

        cancelUploadBtn.addEventListener("click", () => {
            activeFile = null;
            fileInput.value = "";
            previewPanel.classList.add("d-none");
            dropZone.classList.remove("d-none");
            calendarStatus.innerHTML = "";
        });

        confirmUploadBtn.addEventListener("click", () => {
            if (!activeFile) return;

            showLoadingOverlay();
            confirmUploadBtn.disabled = true;
            confirmUploadBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> ${i18n.saving}`;
            cancelUploadBtn.disabled = true;

            const formData = new FormData();
            formData.append("file", activeFile);
            formData.append("courseId", courseId);

            fetch(`/Attendance/UploadCalendar?courseId=${courseId}`, {
                method: "POST",
                body: formData,
                headers: {
                    "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    previewPanel.innerHTML = `
                        <div class="text-success border border-success bg-opacity-10 bg-success p-2 rounded text-center fw-bold animate__animated animate__pulse">
                            <i class="bi bi-check-circle-fill me-1"></i> ${i18n.calendarSavedReloading}
                        </div>
                    `;
                    
                    // Reload the page automatically as requested
                    setTimeout(() => {
                        window.location.reload();
                    }, 800);
                } else {
                    hideLoadingOverlay();
                    confirmUploadBtn.disabled = false;
                    confirmUploadBtn.innerHTML = `<i class="bi bi-check-circle me-1"></i> ${i18n.confirmAndSave}`;
                    cancelUploadBtn.disabled = false;
                    alert(formatString(i18n.errorSavingFormat, data.message));
                }
            })
            .catch(err => {
                hideLoadingOverlay();
                confirmUploadBtn.disabled = false;
                confirmUploadBtn.innerHTML = `<i class="bi bi-check-circle me-1"></i> ${i18n.confirmAndSave}`;
                cancelUploadBtn.disabled = false;
                alert(i18n.errorUploadFailedNetwork);
            });
        });
    </script>
}
