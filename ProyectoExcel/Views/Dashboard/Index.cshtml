@model MvcProyectoExcel.ViewModels.StudentDashboardViewModel
@using Attendance.Infrastructure.Entities
@using System.Globalization
@{
    ViewData["Title"] = SharedLocalizer["MyDashboard"];
}

<div class="mb-4">
    <h1 class="h3">@SharedLocalizer["Hello"], @Model.FullName</h1>
    <p class="text-muted mb-0">@Model.Email</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
else if (Model.Courses.Count == 0)
{
    <div class="alert alert-warning">@SharedLocalizer["NotEnrolled"]</div>
}
else
{
    <form method="get" class="row g-3 align-items-end mb-4">
        <div class="col-md-6">
            <label class="form-label" for="courseId">@SharedLocalizer["CourseLabel"]</label>
            <select class="form-select" id="courseId" name="courseId" onchange="this.form.submit()">
                @foreach (var course in Model.Courses)
                {
                    if (Model.SelectedCourseId == course.Id)
                    {
                        <option value="@course.Id" selected="selected">@course.Name</option>
                    }
                    else
                    {
                        <option value="@course.Id">@course.Name</option>
                    }
                }
            </select>
        </div>
    </form>

    @if (Model.Summary is not null)
    {
        var pct         = (double)Model.Summary.RealAttendancePercentage;
        var pctInvariant = pct.ToString(CultureInfo.InvariantCulture);
        var accent = Model.Summary.AtRiskDrop       ? "border-danger"
                   : !Model.Summary.DiplomaEligible ? "border-warning"
                   : pct < 85                        ? "border-warning"
                   : "border-success";
        var barCss = Model.Summary.AtRiskDrop       ? "ta-progress-bar bg-danger"
                   : !Model.Summary.DiplomaEligible ? "ta-progress-bar bg-warning"
                   : pct < 85                        ? "ta-progress-bar bg-warning"
                   : "ta-progress-bar bg-success";

        <div class="ta-diploma-banner @accent">
            <div class="d-flex align-items-center gap-3">
                @if (Model.Summary.AtRiskDrop)
                {
                    <i class="bi bi-exclamation-triangle-fill fs-2 text-danger flex-shrink-0"></i>
                    <div class="flex-grow-1">
                        <div class="fw-semibold text-danger">@SharedLocalizer["AtRisk"]</div>
                        <div class="small text-muted">@SharedLocalizer["BelowAtRisk"]</div>
                    </div>
                    <span class="badge text-bg-danger fs-6 badge-pulse">@Model.Summary.RealAttendancePercentage%</span>
                }
                else if (!Model.Summary.DiplomaEligible)
                {
                    <i class="bi bi-info-circle-fill fs-2 text-warning flex-shrink-0"></i>
                    <div class="flex-grow-1">
                        <div class="fw-semibold">@SharedLocalizer["Below80"]</div>
                        <div class="small text-muted">@SharedLocalizer["BelowDiploma"]</div>
                    </div>
                    <span class="badge text-bg-warning fs-6">@Model.Summary.RealAttendancePercentage%</span>
                }
                else if (pct < 85)
                {
                    <i class="bi bi-exclamation-circle-fill fs-2 text-warning flex-shrink-0"></i>
                    <div class="flex-grow-1">
                        <div class="fw-semibold">@SharedLocalizer["DiplomaEligible"]</div>
                        <div class="small text-muted">@SharedLocalizer["DiplomaWarning"]</div>
                    </div>
                    <span class="badge text-bg-warning fs-6">@Model.Summary.RealAttendancePercentage%</span>
                }
                else
                {
                    <i class="bi bi-patch-check-fill fs-2 text-success flex-shrink-0"></i>
                    <div class="flex-grow-1">
                        <div class="fw-semibold text-success">@SharedLocalizer["DiplomaEligible"]</div>
                    </div>
                    <span class="badge text-bg-success fs-6">@Model.Summary.RealAttendancePercentage%</span>
                }
            </div>
            <div class="ta-progress mt-3">
                <div class="@barCss" style="width: @pctInvariant%"
                     role="progressbar" aria-valuenow="@pctInvariant" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
            <div class="d-flex justify-content-between small text-muted mt-1">
                <span>0%</span>
                <span>75% ⚠</span>
                <span>80% 🎓</span>
                <span>85% 📋</span>
                <span>100%</span>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="ta-stat-card">
                    <i class="bi bi-calendar3 text-muted d-block mb-1"></i>
                    <div class="ta-stat-value text-primary">@Model.Summary.TotalSessions</div>
                    <div class="ta-stat-label">@SharedLocalizer["LectiveDaysYear"]</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ta-stat-card">
                    <i class="bi bi-check-circle text-success d-block mb-1"></i>
                    <div class="ta-stat-value text-success">@Model.Summary.PresentCount</div>
                    <div class="ta-stat-label">@SharedLocalizer["PresentCount"]</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ta-stat-card">
                    <i class="bi bi-x-circle text-danger d-block mb-1"></i>
                    <div class="ta-stat-value text-danger">@Model.Summary.AbsentCount</div>
                    <div class="ta-stat-label">@SharedLocalizer["AbsentCount"]</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="ta-stat-card">
                    <i class="bi bi-clock text-warning d-block mb-1"></i>
                    <div class="ta-stat-value text-warning">@Model.Summary.LateCount</div>
                    <div class="ta-stat-label">@SharedLocalizer["LateCount"]</div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.SelectedCourseName))
    {
        <h2 class="h5 mb-3">@SharedLocalizer["History"] — @Model.SelectedCourseName</h2>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>@SharedLocalizer["DateHeader"]</th>
                    <th>@SharedLocalizer["StatusHeader"]</th>
                    <th>@SharedLocalizer["CommentHeader"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Records.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">@SharedLocalizer["NoRecordsYet"]</td>
                    </tr>
                }
                else
                {
                    foreach (var record in Model.Records)
                    {
                        <tr>
                            <td>@record.Date.ToString("yyyy-MM-dd")</td>
                            <td>
                                @{
                                    var labelKey = $"Status_{record.Status}";
                                    var labelText = SharedLocalizer[labelKey].Value;
                                    if (string.IsNullOrEmpty(labelText) || labelText == labelKey)
                                    {
                                        labelText = AttendanceStatusDisplay.GetLabel(record.Status);
                                    }
                                }
                                <span class="badge @AttendanceStatusDisplay.GetBadgeClass(record.Status)">
                                    @labelText
                                </span>
                            </td>
                            <td>@(record.Comment ?? "—")</td>
                            <td>
                                @if (record.Status is AttendanceStatus.Absent or AttendanceStatus.Late or AttendanceStatus.EarlyLeave)
                                {
                                    <a href="https://forms.office.com/pages/responsepage.aspx?id=SJ5RaPODX0Ojihp6p3uph2lDlRQhd4BMrzOyCS20Ik9UOFRMMTVRRklONVNXVEY3UjRTVlRJMVY4USQlQCN0PWcu&route=shorturl"
                                       target="_blank" rel="noopener noreferrer"
                                       class="btn btn-sm btn-outline-primary">
                                        @SharedLocalizer["RequestJustification"] &#8599;
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}
