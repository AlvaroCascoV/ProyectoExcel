@model MvcProyectoExcel.ViewModels.StudentDashboardViewModel
@using Attendance.Infrastructure.Entities
@{
    ViewData["Title"] = SharedLocalizer["MyDashboard"];
}

<div class="mb-4">
    <h1 class="h3">@SharedLocalizer["Hello"], @Model.FullName</h1>
    <p class="text-muted mb-0">@Model.Email</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
else if (Model.Courses.Count == 0)
{
    <div class="alert alert-warning">@SharedLocalizer["NotEnrolled"]</div>
}
else
{
    <form method="get" class="row g-3 align-items-end mb-4">
        <div class="col-md-6">
            <label class="form-label" for="courseId">@SharedLocalizer["CourseLabel"]</label>
            <select class="form-select" id="courseId" name="courseId" onchange="this.form.submit()">
                @foreach (var course in Model.Courses)
                {
                    if (Model.SelectedCourseId == course.Id)
                    {
                        <option value="@course.Id" selected="selected">@course.Name</option>
                    }
                    else
                    {
                        <option value="@course.Id">@course.Name</option>
                    }
                }
            </select>
        </div>
    </form>

    @if (Model.Summary is not null)
    {
        @if (Model.Summary.BelowDiplomaWarning)
        {
            <div class="alert alert-warning">
                @SharedLocalizer["RealAttendanceText"] <strong>@Model.Summary.RealAttendancePercentage%</strong>.
                @if (Model.Summary.AtRiskDrop)
                {
                    <span>@SharedLocalizer["BelowAtRisk"]</span>
                }
                else if (!Model.Summary.DiplomaEligible)
                {
                    <span>@SharedLocalizer["BelowDiploma"]</span>
                }
                else
                {
                    <span>@SharedLocalizer["Below80"]</span>
                }
            </div>
        }

        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <div class="display-6 @(Model.Summary.BelowDiplomaWarning ? "text-warning" : "text-primary")">@Model.Summary.RealAttendancePercentage%</div>
                        <div class="small text-muted">@SharedLocalizer["RealAttendanceDiploma"]</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <div class="display-6 text-primary">@Model.Summary.AttendancePercentage%</div>
                        <div class="small text-muted">@SharedLocalizer["Attendance"]</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <div class="h4 mb-0">@Model.Summary.TotalSessions</div>
                        <div class="small text-muted">@SharedLocalizer["LectiveDaysYear"]</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        @if (Model.Summary.AtRiskDrop)
                        {
                            <span class="badge text-bg-danger fs-6">@SharedLocalizer["AtRisk"]</span>
                        }
                        else if (!Model.Summary.DiplomaEligible)
                        {
                            <span class="badge text-bg-warning fs-6">@SharedLocalizer["Below80"]</span>
                        }
                        else if (Model.Summary.BelowDiplomaWarning)
                        {
                            <span class="badge text-bg-warning fs-6">@SharedLocalizer["Below80"]</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success fs-6">@SharedLocalizer["DiplomaEligible"]</span>
                        }
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="small text-muted mb-2">@SharedLocalizer["Breakdown"]</div>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge @AttendanceStatusDisplay.GetBadgeClass(AttendanceStatus.Present)">@SharedLocalizer["PresentCount"]: @Model.Summary.PresentCount</span>
                            <span class="badge @AttendanceStatusDisplay.GetBadgeClass(AttendanceStatus.Absent)">@SharedLocalizer["AbsentCount"]: @Model.Summary.AbsentCount</span>
                            <span class="badge @AttendanceStatusDisplay.GetBadgeClass(AttendanceStatus.Late)">@SharedLocalizer["LateCount"]: @Model.Summary.LateCount</span>
                            <span class="badge @AttendanceStatusDisplay.GetBadgeClass(AttendanceStatus.JustifiedAbsent)">@SharedLocalizer["FJCount"]: @Model.Summary.JustifiedAbsentCount</span>
                            <span class="badge @AttendanceStatusDisplay.GetBadgeClass(AttendanceStatus.JustifiedLate)">@SharedLocalizer["RJCount"]: @Model.Summary.JustifiedLateCount</span>
                            <span class="badge @AttendanceStatusDisplay.GetBadgeClass(AttendanceStatus.EarlyLeave)">@SharedLocalizer["SAFCount"]: @Model.Summary.EarlyLeaveCount</span>
                            <span class="badge @AttendanceStatusDisplay.GetBadgeClass(AttendanceStatus.JustifiedEarlyLeave)">@SharedLocalizer["SAFJCount"]: @Model.Summary.JustifiedEarlyLeaveCount</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.SelectedCourseName))
    {
        <h2 class="h5 mb-3">@SharedLocalizer["History"] — @Model.SelectedCourseName</h2>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>@SharedLocalizer["DateHeader"]</th>
                    <th>@SharedLocalizer["StatusHeader"]</th>
                    <th>@SharedLocalizer["CommentHeader"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Records.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">@SharedLocalizer["NoRecordsYet"]</td>
                    </tr>
                }
                else
                {
                    foreach (var record in Model.Records)
                    {
                        <tr>
                            <td>@record.Date.ToString("yyyy-MM-dd")</td>
                            <td>
                                @{
                                    var labelKey = $"Status_{record.Status}";
                                    var labelText = SharedLocalizer[labelKey].Value;
                                    if (string.IsNullOrEmpty(labelText) || labelText == labelKey)
                                    {
                                        labelText = AttendanceStatusDisplay.GetLabel(record.Status);
                                    }
                                }
                                <span class="badge @AttendanceStatusDisplay.GetBadgeClass(record.Status)">
                                    @labelText
                                </span>
                            </td>
                            <td>@(record.Comment ?? "—")</td>
                            <td>
                                @if (record.Status is AttendanceStatus.Absent or AttendanceStatus.Late or AttendanceStatus.EarlyLeave)
                                {
                                    <a href="https://forms.office.com/pages/responsepage.aspx?id=SJ5RaPODX0Ojihp6p3uph2lDlRQhd4BMrzOyCS20Ik9UOFRMMTVRRklONVNXVEY3UjRTVlRJMVY4USQlQCN0PWcu&route=shorturl"
                                       target="_blank" rel="noopener noreferrer"
                                       class="btn btn-sm btn-outline-primary">
                                        @SharedLocalizer["RequestJustification"] &#8599;
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}
