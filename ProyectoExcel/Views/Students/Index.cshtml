@model MvcProyectoExcel.ViewModels.StudentListViewModel
@{
    ViewData["Title"] = SharedLocalizer["Students"];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">@SharedLocalizer["Students"]</h1>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
else
{
    <form method="get" class="row g-3 align-items-end mb-4">
        <div class="col-md-6">
            <label class="form-label" for="courseId">@SharedLocalizer["CourseLabel"]</label>
            <select class="form-select" id="courseId" name="courseId" onchange="this.form.submit()">
                @foreach (var course in Model.Courses)
                {
                    if (Model.SelectedCourseId == course.Id)
                    {
                        <option value="@course.Id" selected="selected">@course.Name (@course.StudentCount @SharedLocalizer["StudentsText"])</option>
                    }
                    else
                    {
                        <option value="@course.Id">@course.Name (@course.StudentCount @SharedLocalizer["StudentsText"])</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary">@SharedLocalizer["Load"]</button>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.SelectedCourseName))
    {
        <p class="text-muted">@SharedLocalizer["CourseText"] <strong>@Model.SelectedCourseName</strong></p>
    }

    <div class="mb-3">
        <div class="ta-search-wrap">
            <i class="bi bi-search" aria-hidden="true"></i>
            <input type="text" id="studentsSearch" class="form-control form-control-sm"
                   placeholder="@SharedLocalizer["SearchStudents"]" autocomplete="off" />
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>@SharedLocalizer["TableNum"]</th>
                    <th>@SharedLocalizer["TableName"]</th>
                    <th>@SharedLocalizer["TableEmail"]</th>
                    <th>@SharedLocalizer["TableStatus"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Students.Count == 0)
                {
                    <tr><td colspan="4">
                        <div class="ta-empty">
                            <i class="bi bi-inbox" aria-hidden="true"></i>
                            @SharedLocalizer["NoStudentsEnrolled"]
                        </div>
                    </td></tr>
                }
                else
                {
                    var idx = 1;
                    foreach (var student in Model.Students)
                    {
                        var parts    = student.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        var initials = string.Concat(parts.Take(2).Select(w => char.ToUpper(w[0])));
                        var hue      = (student.FullName.Length > 0 ? (int)student.FullName[0] % 8 : 0).ToString();
                        var rowCss   = student.IsActive ? "" : "ta-row-inactive";
                        <tr class="@rowCss">
                            <td class="text-muted small">@idx</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="ta-avatar" data-hue="@hue" aria-hidden="true">@initials</span>
                                    <span class="fw-medium">@student.FullName</span>
                                </div>
                            </td>
                            <td class="small text-muted">@student.Email</td>
                            <td>
                                @if (student.IsActive)
                                {
                                    <span class="badge text-bg-success">@SharedLocalizer["StatusActive"]</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@SharedLocalizer["StatusInactive"]</span>
                                }
                            </td>
                        </tr>
                        idx++;
                    }
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('studentsSearch');
            var tbody = document.querySelector('table tbody');
            if (!input || !tbody) return;

            function normalizeText(value) {
                return (value || '')
                    .toString()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .toLowerCase()
                    .trim();
            }

            input.addEventListener('input', function () {
                var q = normalizeText(input.value);
                tbody.querySelectorAll('tr').forEach(function (row) {
                    if (row.cells.length < 3) return;

                    var name = normalizeText(row.cells[1].textContent);
                    var email = normalizeText(row.cells[2].textContent);
                    var haystack = (name + ' ' + email).trim();
                    row.style.display = !q || haystack.includes(q) ? '' : 'none';
                });
            });
        })();
    </script>
}
