@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <div class="display-1 text-muted mb-3">500</div>
    <h1 class="h3 mb-3">Something went wrong</h1>
    <p class="text-muted mb-4">An unexpected error occurred. Please try again later or contact support if the problem persists.</p>

    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Go to home</a>
</div>
