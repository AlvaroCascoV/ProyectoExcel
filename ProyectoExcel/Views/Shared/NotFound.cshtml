@{
    ViewData["Title"] = "Page not found";
}

<div class="text-center py-5">
    <div class="display-1 text-muted mb-3">404</div>
    <h1 class="h3 mb-3">Page not found</h1>
    <p class="text-muted mb-4">The page you are looking for does not exist or has been moved.</p>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Go to home</a>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Sign in</a>
    }
</div>
