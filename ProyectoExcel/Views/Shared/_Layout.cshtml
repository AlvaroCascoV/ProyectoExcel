@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Options
@using Microsoft.AspNetCore.Builder
@inject IOptions<RequestLocalizationOptions> LocOptions
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentUICulture = requestCulture?.RequestCulture.UICulture.Name;
    var cultureItems = LocOptions.Value.SupportedUICultures
        ?.Select(c => new SelectListItem { Value = c.Name, Text = c.Name == "es" ? "🇪🇸 Español" : "🇬🇧 English", Selected = c.Name == currentUICulture })
        .ToList() ?? new List<SelectListItem>();
    var returnUrl = Context.Request.Path.HasValue ? $"~{Context.Request.Path.Value}{Context.Request.QueryString}" : "~/";
}
<!DOCTYPE html>
<html lang="@requestCulture?.RequestCulture.UICulture.TwoLetterISOLanguageName" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @SharedLocalizer["AppName"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProyectoExcel.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md border-bottom shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                    @SharedLocalizer["AppName"]
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Attendance" asp-action="Index">@SharedLocalizer["PassList"]</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Students" asp-action="Index">@SharedLocalizer["Students"]</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Statistics" asp-action="Index">@SharedLocalizer["Statistics"]</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="https://forms.office.com/pages/responsepage.aspx?id=SJ5RaPODX0Ojihp6p3uph2lDlRQhd4BMrzOyCS20Ik9UOFRMMTVRRklONVNXVEY3UjRTVlRJMVY4USQlQCN0PWcu&route=shorturl" target="_blank" rel="noopener noreferrer">@SharedLocalizer["Justifications"] &#8599;</a>
                                </li>
                            }
                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index">@SharedLocalizer["MyDashboard"]</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="https://forms.office.com/pages/responsepage.aspx?id=SJ5RaPODX0Ojihp6p3uph2lDlRQhd4BMrzOyCS20Ik9UOFRMMTVRRklONVNXVEY3UjRTVlRJMVY4USQlQCN0PWcu&route=shorturl" target="_blank" rel="noopener noreferrer">@SharedLocalizer["Justifications"] &#8599;</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-2">
                            <form id="selectLanguage" asp-controller="Culture" asp-action="SetCulture" asp-route-returnUrl="@returnUrl" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <select name="culture" class="form-select form-select-sm d-inline-block w-auto" onchange="this.form.submit();"
                                        asp-items="cultureItems">
                                </select>
                            </form>
                        </li>
                        <li class="nav-item">
                            <button class="theme-toggle" id="themeToggle" title="@SharedLocalizer["ToggleTheme"]" type="button">
                                <i id="themeIcon" class="bi bi-moon"></i>
                            </button>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="navbar-text me-2 small">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">@SharedLocalizer["Logout"]</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Account" asp-action="Login">@SharedLocalizer["SignIn"]</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container d-flex justify-content-between align-items-center">
            <span>&copy; @DateTime.Now.Year @SharedLocalizer["FooterText"]</span>
            <span class="small">v1.0</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
