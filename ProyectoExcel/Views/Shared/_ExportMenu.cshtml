@model MvcProyectoExcel.ViewModels.ExportMenuViewModel

@if (!string.IsNullOrWhiteSpace(Model.PdfUrl) || !string.IsNullOrWhiteSpace(Model.ExcelUrl))
{
    <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false">
            <i class="bi bi-download"></i> @SharedLocalizer["Export"]
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
            @if (!string.IsNullOrWhiteSpace(Model.PdfUrl))
            {
                <li>
                    <a class="dropdown-item d-flex align-items-center gap-2" href="@Model.PdfUrl">
                        <i class="bi bi-filetype-pdf"></i> @SharedLocalizer["ExportPdf"]
                    </a>
                </li>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ExcelUrl))
            {
                <li>
                    <a class="dropdown-item d-flex align-items-center gap-2" href="@Model.ExcelUrl">
                        <i class="bi bi-file-earmark-excel"></i> @SharedLocalizer["ExportExcel"]
                    </a>
                </li>
            }
        </ul>
    </div>
}

